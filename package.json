{
  "name": "shenbi-maliang-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @shenbi/shared build && concurrently -n web,api -c black,gray \"pnpm --filter @shenbi/web dev\" \"pnpm --filter @shenbi/api dev\"",
    "dev:web": "pnpm --filter @shenbi/shared build && pnpm --filter @shenbi/web dev",
    "dev:api": "pnpm --filter @shenbi/shared build && pnpm --filter @shenbi/api dev",
    "db:validate": "pnpm --filter @shenbi/api db:validate",
    "db:migrate": "pnpm --filter @shenbi/api db:generate && pnpm --filter @shenbi/api db:migrate",
    "db:migrate:dev": "pnpm --filter @shenbi/api db:migrate:dev",
    "local:doctor": "tsx scripts/local-doctor.ts",
    "local:smoke": "tsx scripts/workflow-smoke.ts",
    "build": "pnpm -r build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @shenbi/shared test"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "concurrently": "9.1.2",
    "eslint": "9.17.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
