# 复制本文件为 .env 后使用。API Key 可以先留空，系统会使用本地模拟写作内核。

# 本地数据库和队列，默认配合 docker-compose.yml 使用。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shenbi_agent
REDIS_URL=redis://localhost:6379

# 真实 AI 配置。推荐先用 Kimi 写正文；DeepSeek 适合低成本规划、复盘和改稿。
AI_PROVIDER=kimi

MOONSHOT_API_KEY=
KIMI_TEXT_MODEL=kimi-k2.6
KIMI_BASE_URL=https://api.moonshot.ai/v1

DEEPSEEK_API_KEY=
DEEPSEEK_TEXT_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 本机页面和接口地址。
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# 公开页面采集默认只低并发运行，避免对平台造成压力。
CRAWLER_CONCURRENCY=1

# 本地文件保存位置。
LOCAL_STORAGE_DIR=./storage
WORKSPACE_DIR=./workspace
LOG_DIR=./logs
