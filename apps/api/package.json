{
  "name": "@shenbi/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:validate": "tsx scripts/prisma-with-env.ts validate --schema prisma/schema.prisma",
    "db:generate": "tsx scripts/prisma-with-env.ts generate --schema prisma/schema.prisma",
    "db:migrate": "tsx scripts/prisma-with-env.ts migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "tsx scripts/prisma-with-env.ts migrate dev --schema prisma/schema.prisma",
    "db:studio": "tsx scripts/prisma-with-env.ts studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "@prisma/client": "6.1.0",
    "@shenbi/shared": "workspace:*",
    "bullmq": "5.34.2",
    "cheerio": "1.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "ioredis": "5.4.2",
    "playwright-core": "1.49.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "prisma": "6.1.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
